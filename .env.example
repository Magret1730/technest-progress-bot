# Bot User OAuth Token from https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-token-here

# Chan Meng's Slack member ID (recommended — opens DM automatically)
SLACK_USER_ID=U0123456789

# Optional fallback: DM channel ID from huddle URL
SLACK_CHANNEL_ID=D0ATNMZ78AH

# Default dashboard settings (used when no saved settings exist)
MESSAGE_TEXT=Hello Chan
SCHEDULE_CRON=0 12 * * 0
BOT_STATUS=Active

# Cron note: local scripts use your machine timezone.
# Vercel cron uses UTC — adjust vercel.json if needed.

# Vercel KV (required on Vercel for persistent dashboard settings)
# Create a KV store in Vercel → Storage, then link these env vars:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=

# Protect POST /api/send-message test button (never expose in frontend source)
TEST_API_SECRET=choose-a-long-random-string

# Protect /api/cron/send-message (Vercel sends Authorization: Bearer CRON_SECRET)
CRON_SECRET=choose-another-long-random-string
